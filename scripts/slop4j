#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"

find_cli_jar() {
  [[ -d "${repo_root}/slop4j-cli/target" ]] || return 0

  find "${repo_root}/slop4j-cli/target" -maxdepth 1 -type f -name "slop4j-cli-*.jar" \
    ! -name "original-*" \
    ! -name "*-javadoc.jar" \
    ! -name "*-sources.jar" \
    | sort \
    | tail -n 1
}

jar="$(find_cli_jar || true)"

if [[ "${SLOP4J_REBUILD:-0}" == "1" || ! -f "${jar}" ]]; then
  (cd "${repo_root}" && mvn -q -B -pl slop4j-cli -am package)
  jar="$(find_cli_jar || true)"
fi

if [[ -z "${jar}" || ! -f "${jar}" ]]; then
  echo "Could not find slop4j CLI jar after build." >&2
  exit 1
fi

exec java -jar "${jar}" "$@"
